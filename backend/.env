PORT=5000
CORS_ORIGIN=http://localhost:5173,http://127.0.0.1:5173

# MongoDB Atlas Connection
# Format: mongodb+srv://username:password@cluster-name.mongodb.net/database-name?retryWrites=true&w=majority
# Replace with your actual MongoDB Atlas credentials
MONGODB_URI=mongodb+srv://username:password@cluster-name.mongodb.net/garments-production-tracker?retryWrites=true&w=majority

# Admin seed credentials (used by seed-admin script)
ADMIN_EMAIL=admin@production.local
ADMIN_NAME=System Administrator

# For local development (uncomment to use instead of Atlas):
# MONGODB_URI=mongodb://127.0.0.1:27017/garments-production-tracker

