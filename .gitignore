node_modules/
yarn.lock
pnpm-lock.yaml

# IDE and Editor
.vscode/
.idea/
*.code-workspace
*.sublime-project
*.sublime-workspace

# Logs
logs/
*.log
npm-debug.log*

# OS
.DS_Store
.AppleDouble
.LSOverride
Thumbs.db

# Build outputs
dist/
build/
*.bak

# MongoDB Memory Server
.mongodb/

